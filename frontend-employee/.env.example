# Frontend env (Vite) — copy to .env for local dev.
# In production (GitHub Pages deploy), these are injected from GitHub Secrets
# of the same name during the build step in .github/workflows/deploy-employee-pages.yml.

# Supabase — self-hosted on VPS SumoPod (43.157.247.84:8000 by default).
# For GH Pages prod, point this at an HTTPS endpoint (mixed-content blocks HTTP)
# e.g. https://supabase.mshadianto.id once you've fronted it with TLS.
VITE_SUPABASE_URL=http://43.157.247.84:8000
VITE_SUPABASE_ANON_KEY=__paste_anon_public_key__

# Backend FastAPI URL. Local: http://localhost:8000. Prod: your hosted backend.
VITE_API_URL=http://localhost:8000
